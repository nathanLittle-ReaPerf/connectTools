# (import name, pip package name, why it's needed)
_DEPS = [
    ("boto3",    "boto3",    "AWS API calls — flow map and log export"),
    ("botocore", "botocore", "AWS SDK core — comes with boto3"),
]

def _check_deps() -> None:
    missing = [(pip, why) for imp, pip, why in _DEPS if not _importable(imp)]
    if not missing:
        return

    print()
    hr()
    print(yellow("  Missing dependencies:"))
    print()
    for pip, why in missing:
        print(f"    {bold(pip):30}  {dim(why)}")
    print()
    hr()
    print()

    if not ask_yn("Install missing packages now?", default=True):
        print(red("  Cannot continue without required packages."))
        print(dim("  Run:  pip install boto3 --user"))
        sys.exit(1)

    print()
    failed = []
    for pip, _ in missing:
        print(f"  Installing {cyan(pip)} ...")
        rc = subprocess.run(
            [sys.executable, "-m", "pip", "install", pip, "--user"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        ).returncode
        if rc != 0:
            # Retry without --user (e.g. CloudShell root env)
            rc = subprocess.run(
                [sys.executable, "-m", "pip", "install", pip],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            ).returncode
        if rc == 0:
            print(f"    {green('✓')} {pip}")
        else:
            print(f"    {red('✗')} {pip} — install failed")
            failed.append(pip)

    if failed:
        print()
        print(red(f"  Could not install: {', '.join(failed)}"))
        print(dim("  Try manually:  pip install boto3 --user"))
        sys.exit(1)

    print()
    print(green("  All dependencies installed."))
    print()
    # Restart so newly installed packages are importable
    os.execv(sys.executable, [sys.executable] + sys.argv)


def _importable(name: str) -> bool:
    try:
        __import__(name)
        return True
    except ImportError:
        return False


