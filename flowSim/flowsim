import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).parent

# ── Terminal helpers ───────────────────────────────────────────────────────────

def _c(code: str, text: str) -> str:
    if not sys.stdout.isatty():
        return text
    return f"\033[{code}m{text}\033[0m"

def bold(t):    return _c("1", t)
def dim(t):     return _c("2", t)
def cyan(t):    return _c("96", t)
def green(t):   return _c("92", t)
def yellow(t):  return _c("93", t)
def red(t):     return _c("91", t)

def hr():
    print(dim("─" * 60))

def header(title: str):
    print()
    hr()
    print(bold(f"  {title}"))
    hr()

def ask(prompt: str, default: str = "") -> str:
    hint = f" [{default}]" if default else ""
    try:
        val = input(f"  {prompt}{hint}: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return default
    return val if val else default

def ask_required(prompt: str) -> str:
    while True:
        val = ask(prompt)
        if val:
            return val
        print(red("  Required. Please enter a value."))

def ask_file(prompt: str, must_exist: bool = True, default: str = "") -> str:
    while True:
        val = ask(prompt, default)
        if not val:
            print(red("  Required. Please enter a file path."))
            continue
        if must_exist and not Path(val).exists():
            print(red(f"  File not found: {val}"))
            continue
        return val

def ask_yn(prompt: str, default: bool = True) -> bool:
    hint = "Y/n" if default else "y/N"
    val = ask(f"{prompt} [{hint}]").lower()
    if not val:
        return default
    return val.startswith("y")

# ── Arrow-key input ────────────────────────────────────────────────────────────

def _supports_raw() -> bool:
    """True if the terminal supports raw keystroke input."""
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        return False
    try:
        import tty, termios  # noqa: F401
        return True
    except ImportError:
        pass
    if sys.platform == "win32":
        try:
            import msvcrt  # noqa: F401
            return True
        except ImportError:
            pass
    return False


def _read_key() -> str:
    """Block until a keypress; return a normalized string."""
    if sys.platform != "win32":
        import tty, termios
        import select as _sel
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            ch = sys.stdin.buffer.read(1)
            if ch == b"\x1b":
                # Read the rest of the escape sequence in the same raw-mode
                # session — avoids the race condition of restore/re-enter.
                if _sel.select([sys.stdin], [], [], 0.05)[0]:
                    rest = sys.stdin.buffer.read(2)
                    if rest == b"[A": return "UP"
                    if rest == b"[B": return "DOWN"
                return "ESC"
            return ch.decode("utf-8", errors="replace")
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
    else:
        # Windows (winpty/ConPTY): stdin is a pipe that delivers ANSI sequences.
        # Use threading timeout so a bare Escape key doesn't block forever.
        import threading
        import queue as _q

        def _read_n(n: int, timeout: float) -> bytes:
            q: _q.Queue = _q.Queue()
            threading.Thread(
                target=lambda: q.put(sys.stdin.buffer.read(n)),
                daemon=True,
            ).start()
            try:
                return q.get(timeout=timeout)
            except _q.Empty:
                return b""

        ch = _read_n(1, 30.0)
        if not ch:
            return ""
        if ch == b"\x1b":
            rest = _read_n(2, 0.05)   # 50 ms — arrives immediately for arrow keys
            if rest == b"[A": return "UP"
            if rest == b"[B": return "DOWN"
            return "ESC"
        return ch.decode("utf-8", errors="replace")


def pick_menu(title: str, options: list[tuple[str, str]]) -> str | None:
    """Arrow-key menu with numbered fallback when raw input is unavailable."""
    if not options:
        return None
    if not _supports_raw():
        return _pick_menu_numbered(title, options)

    n = len(options)
    sel = 0
    first_draw = True

    def render() -> None:
        nonlocal first_draw
        lines = [
            "",
            bold(f"  {title}"),
            "",
        ]
        for i, (_, label) in enumerate(options):
            if i == sel:
                lines.append(f"  {green('▶')}  {bold(label)}")
            else:
                lines.append(f"     {label}")
        lines.append(dim("  ↑ ↓  move    Enter  select    0 · Esc  back"))

        if not first_draw:
            sys.stdout.write(f"\x1b[{len(lines)}A")
        for line in lines:
            sys.stdout.write(f"\x1b[2K{line}\n")
        sys.stdout.flush()
        first_draw = False

    render()
    # Discard any characters already in the input buffer (e.g. terminal
    # initialization sequences that arrived before we started reading).
    if sys.platform != "win32":
        try:
            import termios
            termios.tcflush(sys.stdin.fileno(), termios.TCIFLUSH)
        except Exception:
            pass
    while True:
        k = _read_key()
        if k == "UP":
            sel = (sel - 1) % n
            render()
        elif k == "DOWN":
            sel = (sel + 1) % n
            render()
        elif k in ("\r", "\n"):
            print()
            return options[sel][0]
        elif k in ("0", "ESC", "q"):
            print()
            return None
        elif k == "\x03":  # Ctrl+C
            print()
            raise KeyboardInterrupt


def _pick_menu_numbered(title: str, options: list[tuple[str, str]]) -> str | None:
    """Numbered fallback when arrow-key input is unavailable."""
    print()
    print(bold(f"  {title}"))
    print()
    for i, (_, label) in enumerate(options, 1):
        print(f"  {cyan(str(i))}.  {label}")
    print(f"  {dim('0')}.  {dim('Back / Exit')}")
    print()
    while True:
        raw = ask("Select")
        if raw == "0" or raw == "":
            return None
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(options):
                return options[idx][0]
        except ValueError:
            pass
        print(red(f"  Enter a number between 0 and {len(options)}."))

def run(cmd: list[str]) -> int:
    """Run a subprocess and return its exit code."""
    print()
    hr()
    print(dim(f"  $ {' '.join(cmd)}"))
    hr()
    print()
    result = subprocess.run(cmd)
    print()
    return result.returncode

def script(name: str) -> str:
    return str(SCRIPT_DIR / name)

def load_json(path: str) -> dict | None:
    try:
        return json.loads(Path(path).read_text(encoding="utf-8"))
    except Exception:
        return None

# ── Toolbox output directory ───────────────────────────────────────────────────
# flowSim lives one level below connectTools root (connectTools/flowSim/flowsim)
TOOLBOX_ROOT = SCRIPT_DIR.parent

def toolbox_output_dir(tool_name: str) -> Path:
    folder = "".join(w.capitalize() for w in tool_name.split("_"))
    return TOOLBOX_ROOT / folder


def pick_log_files() -> list[str] | None:
    """Let user select one or more CW log export files.

    Browses flowSim/Logs/ (exports from export_flow_logs.py) and
    connectTools/ContactLogs/ (exports from the toolbox), newest first.
    """
    import glob as _glob

    own_logs_dir     = SCRIPT_DIR / "Logs"
    toolbox_logs_dir = toolbox_output_dir("contact_logs")

    candidates: list[Path] = []
    if own_logs_dir.exists():
        candidates += sorted(own_logs_dir.glob("*.json"), reverse=True)
    if toolbox_logs_dir.exists():
        candidates += sorted(toolbox_logs_dir.glob("*.json"), reverse=True)

    if candidates:
        print()
        print(bold("  Available log exports:"))
        print()
        for i, p in enumerate(candidates, 1):
            size_kb = p.stat().st_size // 1024
            source  = dim("flowSim") if own_logs_dir in p.parents else dim("toolbox")
            print(f"  {cyan(str(i)):>6}.  {p.name}  {dim(f'({size_kb} KB)')}  {source}")
        print(f"  {cyan('n')}.  Enter path(s) manually")
        print(f"  {dim('0')}.  Back")
        print()
        print(dim("  Enter numbers separated by spaces to select multiple (e.g. 1 3 5)"))
        print()

        while True:
            raw = ask("Select file(s)").strip()
            if raw == "0" or raw == "":
                return None
            if raw.lower() == "n":
                break
            parts = raw.split()
            selected: list[str] = []
            valid = True
            for p in parts:
                try:
                    idx = int(p) - 1
                    if 0 <= idx < len(candidates):
                        selected.append(str(candidates[idx]))
                    else:
                        print(red(f"  Number out of range: {p}"))
                        valid = False
                        break
                except ValueError:
                    print(red(f"  Not a number: {p}"))
                    valid = False
                    break
            if valid and selected:
                return selected

    # Manual entry fallback
    print()
    print(dim("  Enter one or more file paths, space-separated, or a glob (e.g. logs/*.json)"))
    raw = ask_required("Log file(s)")
    log_files: list[str] = []
    for part in raw.split():
        expanded = _glob.glob(part)
        if expanded:
            log_files.extend(expanded)
        else:
            log_files.append(part)
    return log_files if log_files else None


# ── Cache helpers ──────────────────────────────────────────────────────────────

CACHE_BASE = Path.home() / ".connecttools" / "flows"

def cached_instances() -> list[str]:
    if not CACHE_BASE.exists():
        return []
    return [d.name for d in sorted(CACHE_BASE.iterdir()) if d.is_dir()]

def cached_flow_names(instance_id: str) -> list[str]:
    d = CACHE_BASE / instance_id
    names = []
    for p in sorted(d.glob("*.json")):
        if p.name == "manifest.json":
            continue
        try:
            env = json.loads(p.read_text())
            name = env.get("metadata", {}).get("name", "")
            if name:
                names.append(name)
        except Exception:
            pass
    return sorted(names)

def cache_info(instance_id: str) -> str:
    manifest_path = CACHE_BASE / instance_id / "manifest.json"
    if not manifest_path.exists():
        return dim("no cache")
    try:
        m = json.loads(manifest_path.read_text())
        age_days = (
            __import__("datetime").datetime.now(__import__("datetime").timezone.utc)
            - __import__("datetime").datetime.fromisoformat(m["fetched_at"])
        ).days
        return dim(f"{m.get('flow_count','?')} flows, {age_days}d old")
    except Exception:
        return dim("cache unreadable")

def pick_instance() -> str | None:
    instances = cached_instances()
    if not instances:
        return ask_required("Instance ID (UUID)")
    print()
    print(bold("  Cached instances:"))
    print()
    for i, iid in enumerate(instances, 1):
        info = cache_info(iid)
        print(f"  {cyan(str(i))}.  {iid}  {info}")
    print(f"  {cyan('n')}.  Enter a different ID")
    print(f"  {dim('0')}.  Back")
    print()
    while True:
        raw = ask("Select").strip()
        if raw == "0" or raw == "":
            return None
        if raw.lower() == "n":
            return ask_required("Instance ID (UUID)")
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(instances):
                return instances[idx]
        except ValueError:
            pass
        # If they just typed a UUID directly, accept it
        if len(raw) == 36 and raw.count("-") == 4:
            return raw
        print(red("  Enter a number, 'n', or a UUID."))

def pick_flow(instance_id: str) -> str | None:
    names = cached_flow_names(instance_id)
    if not names:
        return ask_required("Starting flow name")
    print()
    print(bold("  Flows in cache:"))
    print()
    for i, name in enumerate(names, 1):
        print(f"  {cyan(str(i)):>6}.  {name}")
    print(f"  {cyan('n')}.  Type a flow name manually")
    print(f"  {dim('0')}.  Back")
    print()
    while True:
        raw = ask("Select").strip()
        if raw == "0" or raw == "":
            return None
        if raw.lower() == "n":
            return ask_required("Flow name")
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(names):
                return names[idx]
        except ValueError:
            pass
        print(red(f"  Enter a number, 'n', or 0 to go back."))

def _scenario_label(p: Path) -> tuple[str, str]:
    """Return (name, hint) for display. name is _name or filename stem, hint is contact count or note snippet."""
    d = load_json(str(p))
    if not d:
        return p.stem, ""
    name = d.get("_name") or p.stem
    count = d.get("_contact_count")
    hint = f"{count} contact(s)" if count else d.get("_note", "")[:60]
    return name, hint


def pick_scenario(default: str = "") -> str | None:
    scenarios_dir = SCRIPT_DIR / "Scenarios"
    candidates: list[Path] = []
    if scenarios_dir.exists():
        seen: set[str] = set()
        for pat in ("scenario*.json", "archetype*.json"):
            for p in sorted(scenarios_dir.glob(pat)):
                if p.name not in seen:
                    candidates.append(p)
                    seen.add(p.name)
        candidates.sort(key=lambda p: p.name)

    if not candidates:
        return ask_file("Scenario JSON file", must_exist=True, default=default) or None

    print()
    print(bold("  Scenarios:"))
    print()
    max_name = 0
    labels = [_scenario_label(p) for p in candidates]
    max_name = max((len(name) for name, _ in labels), default=20)
    for i, (p, (name, hint)) in enumerate(zip(candidates, labels), 1):
        name_col = bold(name.ljust(max_name))
        hint_col = dim(f"  {hint}") if hint else ""
        print(f"  {cyan(str(i)):>6}.  {name_col}{hint_col}")
    print(f"  {cyan('n')}.  Enter a different path")
    print(f"  {dim('0')}.  Back")
    print()
    while True:
        raw = ask("Select").strip()
        if raw == "0" or raw == "":
            return None
        if raw.lower() == "n":
            return ask_file("Scenario JSON file", must_exist=True) or None
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(candidates):
                return str(candidates[idx])
        except ValueError:
            pass
        print(red("  Enter a number or 'n'."))

# ── Action: map instance ───────────────────────────────────────────────────────

def action_map():
    header("Map Instance  —  flow_map.py")
    print("  Scans all flows, builds the attribute/Lambda map, and generates")
    print("  an HTML report and scenario template.")
    print()

    instance_id = pick_instance()
    if not instance_id:
        return

    instances_with_cache = cached_instances()
    force_refresh = False
    if instance_id in instances_with_cache:
        force_refresh = ask_yn("Cache exists. Force re-fetch from AWS?", default=False)

    region = ""
    if force_refresh or instance_id not in instances_with_cache:
        region = ask_required("AWS region (e.g. us-east-1)")

    profile = ask("AWS profile (leave blank for default)", default="")
    no_html = ask_yn("Generate HTML report?", default=True)
    no_scenario = ask_yn("Generate scenario template?", default=True)

    cmd = [sys.executable, script("flow_map.py"), "--instance-id", instance_id]
    if region:
        cmd += ["--region", region]
    if profile:
        cmd += ["--profile", profile]
    if force_refresh:
        cmd.append("--force-refresh")
    if not no_html:
        cmd.append("--no-html")
    if not no_scenario:
        cmd.append("--no-scenario")

    run(cmd)

# ── Action: simulate ───────────────────────────────────────────────────────────

def action_simulate():
    header("Simulate Flow  —  flow_sim.py")
    print("  Walk a contact flow step by step using a scenario file.")
    print()

    instance_id = pick_instance()
    if not instance_id:
        return

    if not cached_flow_names(instance_id):
        print(yellow("  No flow cache found for this instance. Run 'Map Instance' first."))
        return

    flow_name = pick_flow(instance_id)
    if not flow_name:
        return

    scenario = pick_scenario()
    if not scenario:
        return

    interactive = ask_yn("Interactive mode (prompt at unresolved forks)?", default=False)
    save_choices = False
    if interactive:
        save_choices = ask_yn("Save choices back to scenario file?", default=False)

    html_default = f"sim_{flow_name.replace(' ','_')}.html"
    no_html = not ask_yn(f"Generate HTML visualization? [{html_default}]", default=True)
    html_path = ""
    if not no_html:
        custom = ask(f"HTML output path", default=html_default)
        html_path = custom

    cmd = [
        sys.executable, script("flow_sim.py"),
        "--instance-id", instance_id,
        "--flow", flow_name,
        "--scenario", scenario,
    ]
    if interactive:
        cmd.append("--interactive")
    if save_choices:
        cmd.append("--save-choices")
    if no_html:
        cmd.append("--no-html")
    elif html_path and html_path != html_default:
        cmd += ["--html", html_path]

    run(cmd)

# ── Action: build scenarios from logs ─────────────────────────────────────────

def action_from_logs():
    header("Build Scenarios from Logs  —  scenario_from_logs.py")
    print("  Parse exported CloudWatch flow logs and generate scenario files")
    print("  pre-filled with real attribute values from actual contacts.")
    print()

    log_files = pick_log_files()
    if not log_files:
        return
    print(green(f"  {len(log_files)} file(s) selected."))

    print()
    mode = pick_menu("Output mode", [
        ("top",        "Top N journeys (one scenario per unique flow path)"),
        ("archetypes", "Archetypes (named scenarios by decision-attribute profile)"),
        ("merge",      "Merged (single scenario combining all contacts)"),
        ("single",     "Single contact by ID"),
    ])
    if mode is None:
        return

    contact_id = ""
    top_n = 5
    instance_id = ""
    if mode == "single":
        contact_id = ask_required("Contact ID (UUID or prefix)")
    elif mode == "top":
        top_n = int(ask("How many top journeys?", default="5") or "5")
    elif mode == "archetypes":
        print()
        print(dim("  Archetypes uses the flow map cache to find decision attributes."))
        print(dim("  Run 'Map Instance' first if you haven't already."))
        print()
        instance_id = pick_instance() or ""
        if not instance_id:
            return

    out_dir = ask("Output directory", default=str(SCRIPT_DIR / "Scenarios"))
    anonymize = ask_yn("Anonymize PII in attribute values?", default=False)

    cmd = [sys.executable, script("scenario_from_logs.py")] + log_files
    cmd += ["--out-dir", out_dir]
    if mode == "merge":
        cmd.append("--merge")
    elif mode == "single":
        cmd += ["--contact-id", contact_id]
    elif mode == "archetypes":
        cmd.append("--archetypes")
        cmd += ["--instance-id", instance_id]
    else:
        cmd += ["--top", str(top_n)]
    if anonymize:
        cmd.append("--anonymize")

    run(cmd)

# ── Action: export logs ────────────────────────────────────────────────────────

def action_export_logs():
    header("Export Flow Logs  —  export_flow_logs.py")
    print("  Fetch Amazon Connect contact flow logs from CloudWatch and save")
    print("  them to flowSim/Logs/ ready for the scenario builder.")
    print()

    instance_id = pick_instance()
    if not instance_id:
        return

    region = ask_required("AWS region (e.g. us-east-1)")
    profile = ask("AWS profile (leave blank for default)", default="")

    print()
    time_choice = pick_menu("Time range", [
        ("yesterday", "Yesterday (previous calendar day, UTC)"),
        ("last_week", "Last 7 days"),
        ("last",      "Rolling window (e.g. 4h, 2d)"),
        ("custom",    "Custom start / end dates"),
    ])
    if time_choice is None:
        return

    time_args: list[str] = []
    if time_choice == "yesterday":
        time_args = ["--yesterday"]
    elif time_choice == "last_week":
        time_args = ["--last-week"]
    elif time_choice == "last":
        duration = ask_required("Duration (e.g. 4h, 2d, 1w)")
        time_args = ["--last", duration]
    elif time_choice == "custom":
        start = ask_required("Start date/time (YYYY-MM-DD or YYYY-MM-DDTHH:MM:SS UTC)")
        end   = ask("End date/time (leave blank for now)", default="")
        time_args = ["--start", start]
        if end:
            time_args += ["--end", end]

    max_raw = ask("Max contacts to export (default 100; 0 for unlimited)", default="100")
    try:
        max_contacts = int(max_raw)
    except ValueError:
        max_contacts = 100

    out_dir = ask("Output directory", default=str(SCRIPT_DIR / "Logs"))

    out_dir_path = Path(out_dir)

    cmd = [
        sys.executable, script("export_flow_logs.py"),
        "--instance-id", instance_id,
        "--region", region,
    ]
    if profile:
        cmd += ["--profile", profile]
    cmd += time_args
    cmd += ["--max", str(max_contacts), "--out-dir", out_dir]

    rc = run(cmd)
    if rc != 0:
        return

    # Find the most recently written file in the output dir
    written: list[Path] = sorted(out_dir_path.glob("*.json"), key=lambda p: p.stat().st_mtime, reverse=True) if out_dir_path.exists() else []
    if not written:
        return

    latest = written[0]
    print(green(f"  Log file ready: {latest.name}"))
    print()

    if not ask_yn("Build scenarios from this export now?", default=True):
        return

    print()
    mode = pick_menu("Output mode", [
        ("top",        "Top N journeys (one scenario per unique flow path)"),
        ("archetypes", "Archetypes (named scenarios by decision-attribute profile)"),
        ("merge",      "Merged (single scenario combining all contacts)"),
    ])
    if mode is None:
        return

    top_n = 5
    archetype_instance = instance_id
    if mode == "top":
        top_n = int(ask("How many top journeys?", default="5") or "5")
    elif mode == "archetypes":
        print()
        print(dim("  Using instance cache from the export. Run 'Map Instance' first if needed."))
        archetype_instance = ask("Instance ID", default=instance_id) or instance_id

    scenario_dir = ask("Scenario output directory", default=str(SCRIPT_DIR / "Scenarios"))
    anonymize = ask_yn("Anonymize PII in attribute values?", default=False)

    scen_cmd = [sys.executable, script("scenario_from_logs.py"), str(latest), "--out-dir", scenario_dir]
    if mode == "merge":
        scen_cmd.append("--merge")
    elif mode == "archetypes":
        scen_cmd += ["--archetypes", "--instance-id", archetype_instance]
    else:
        scen_cmd += ["--top", str(top_n)]
    if anonymize:
        scen_cmd.append("--anonymize")

    run(scen_cmd)

